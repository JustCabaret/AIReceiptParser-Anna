{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "llm.complete",
    "storage.read",
    "storage.write"
  ],
  "required_executas": [
    {
      "tool_id": "bundled:receipt-parser-tool"
    },
    {
      "tool_id": "bundled:receipt-copilot-coach"
    }
  ],
  "system_prompt_addendum": "You are Receipt Expense Copilot. Help the user manage, parse, and analyze their receipt expenses. When asked to process a receipt image or view expense history, use the open_app_view tool to open the main dashboard.",
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html"
    },
    "views": [
      {
        "name": "main",
        "title": "Receipt Expense Copilot",
        "default": true,
        "default_size": {
          "w": 960,
          "h": 680
        },
        "min_size": {
          "w": 640,
          "h": 480
        },
        "single_instance": true,
        "summary_template": "Receipt Copilot dashboard active."
      }
    ],
    "host_api": {
      "tools": [
        "required:*"
      ],
      "llm": [
        "complete"
      ],
      "storage": [
        "get",
        "set",
        "delete",
        "list"
      ],
      "upload": [
        "inline",
        "negotiate",
        "confirm"
      ],
      "window": [
        "set_title",
        "open_view",
        "close"
      ],
      "agent": {
        "session": {
          "auto": true,
          "fixed": {
            "client_ids": []
          }
        },
        "tools": []
      },
      "image": [
        "generate",
        "edit"
      ]
    }
  }
}
